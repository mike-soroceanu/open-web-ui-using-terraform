*.tfstate.lock.info

# Terraform variables (may contain secrets)
terraform.tfvars
*.auto.tfvars

# Terraform internals
.terraform/
.terraform.lock.hcl
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan files
*.tfplan
myplan

# Crash logs
crash.log
crash.*.log
